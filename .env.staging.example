# Staging environment template.
# Copy to .env.staging and replace every change-me/example/fake value with a
# controlled staging secret from your secret manager before deployment.
# Do not commit .env.staging or any real secret.

NEW_API_IMAGE=calciumion/new-api:latest
NEW_API_PORT=3001
TZ=Asia/Shanghai
NODE_NAME=staging-new-api-node-1

# Database and cache. Placeholders only.
POSTGRES_USER=new_api
POSTGRES_PASSWORD=change-me-staging-postgres-password
POSTGRES_DB=new_api
SQL_DSN=postgresql://new_api:change-me-staging-postgres-password@postgres:5432/new_api
REDIS_PASSWORD=change-me-staging-redis-password
REDIS_CONN_STRING=redis://:change-me-staging-redis-password@redis:6379

# Application secrets. Placeholders only.
SESSION_SECRET=change-me-staging-session-secret
CRYPTO_SECRET=change-me-staging-crypto-secret

# Runtime policy.
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
STORE_FULL_TEXT_ENABLED=false
STREAMING_TIMEOUT=300

# Provider keys must be configured through protected admin/provider-account
# workflows or a secret manager. Do not place real upstream API keys here.
# OPENAI_API_KEY=change-me-staging-provider-key-placeholder
